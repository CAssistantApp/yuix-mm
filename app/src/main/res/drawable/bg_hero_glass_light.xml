<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#F8FFFFFF"
                android:centerColor="#D9FFFFFF"
                android:endColor="#AFFFFFFF" />
            <corners android:radius="36dp" />
        </shape>
    </item>
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#52FFFFFF"
                android:centerColor="#18FFFFFF"
                android:endColor="#08B8DFFF" />
            <stroke android:width="1dp" android:color="#F8FFFFFF" />
            <corners android:radius="35dp" />
        </shape>
    </item>
    <item android:left="12dp" android:top="10dp" android:right="12dp" android:bottom="70dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="180"
                android:startColor="#52FFFFFF"
                android:endColor="#00FFFFFF" />
            <corners android:radius="28dp" />
        </shape>
    </item>
</layer-list>
