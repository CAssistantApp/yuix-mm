<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#BFFFFFFF" />
            <corners android:radius="30dp" />
        </shape>
    </item>
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#EFFFFFFF"
                android:centerColor="#A8FFFFFF"
                android:endColor="#72FFFFFF" />
            <stroke android:width="1dp" android:color="#F4FFFFFF" />
            <corners android:radius="29dp" />
        </shape>
    </item>
    <item android:left="10dp" android:top="8dp" android:right="10dp" android:bottom="46dp">
        <shape android:shape="rectangle">
            <solid android:color="#32FFFFFF" />
            <corners android:radius="22dp" />
        </shape>
    </item>
</layer-list>
